{
  "title": "ALB Metrics",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,


  "panels": [
    {
      "type": "timeseries",
      "title": "Request Count",
      "datasource": {
        "type": "cloudwatch"
      },
      "targets": [
        {
          "namespace": "AWS/ApplicationELB",
          "metricName": "RequestCount",
          "statistics": ["Sum"],
          "region": "{{ aws_region }}",
          "dimensions": {
            "LoadBalancer": "{{ alb_arn_suffix }}"
          }
        }
      ],


      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },



    {
      "type": "timeseries",
      "title": "Target Response Time",
      "datasource": {
        "type": "cloudwatch"
      },
      "targets": [
        {
          "namespace": "AWS/ApplicationELB",
          "metricName": "TargetResponseTime",
          "statistics": ["Average"],
          "region": "{{ aws_region }}",
          "dimensions": {
            "LoadBalancer": "{{ alb_arn_suffix }}"
          }
        }
      ],


      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },




    {
      "type": "timeseries",
      "title": "5XX Errors",
      "datasource": {
        "type": "cloudwatch"
      },
      "targets": [
        {
          "namespace": "AWS/ApplicationELB",
          "metricName": "HTTPCode_Target_5XX_Count",
          "statistics": ["Sum"],
          "region": "{{ aws_region }}",
          "dimensions": {
            "LoadBalancer": "{{ alb_arn_suffix }}"
          }
        }
      ],


      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },



    {
      "type": "timeseries",
      "title": "Healthy Host Count",
      "datasource": {
        "type": "cloudwatch"
      },
      "targets": [
        {
          "namespace": "AWS/ApplicationELB",
          "metricName": "HealthyHostCount",
          "statistics": ["Average"],
          "region": "{{ aws_region }}",
          "dimensions": {
            "LoadBalancer": "{{ alb_arn_suffix }}"
          }
        }
      ],


      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    }



  ]
}